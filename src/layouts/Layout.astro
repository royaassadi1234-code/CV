---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "My Professional CV" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
      }

      body {
        background: #f8f9fa;
      }

      .cv-container {
        max-width: 900px;
        margin: 40px auto;
        background: white;
        border-radius: 10px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }

      .cv-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 60px 40px;
        text-align: center;
      }

      .cv-header h1 {
        font-size: 3em;
        margin-bottom: 10px;
        font-weight: 700;
      }

      .cv-header .title {
        font-size: 1.5em;
        opacity: 0.95;
        margin-bottom: 20px;
      }

      .cv-header .contact-info {
        font-size: 1em;
        display: flex;
        justify-content: center;
        gap: 30px;
        flex-wrap: wrap;
      }

      .cv-content {
        padding: 40px;
      }

      .cv-section {
        margin-bottom: 40px;
      }

      .cv-section:last-child {
        margin-bottom: 0;
      }

      .section-title {
        font-size: 1.8em;
        color: #667eea;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 3px solid #667eea;
        font-weight: 600;
      }

      .entry {
        margin-bottom: 25px;
        padding-left: 20px;
        border-left: 3px solid #667eea;
      }

      .entry-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 8px;
        flex-wrap: wrap;
      }

      .entry-title {
        font-size: 1.2em;
        font-weight: 600;
        color: #333;
      }

      .entry-subtitle {
        font-size: 1em;
        color: #666;
        font-style: italic;
      }

      .entry-date {
        font-size: 0.95em;
        color: #999;
        font-weight: 500;
      }

      .entry-description {
        color: #555;
        line-height: 1.6;
        margin-top: 8px;
      }

      .skills-list {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 15px;
      }

      .skill-tag {
        background: #667eea;
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.95em;
        font-weight: 500;
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 15px;
      }

      .project-card {
        background: #f8f9fa;
        padding: 20px;
        border-radius: 8px;
        border-left: 4px solid #667eea;
      }

      .project-title {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
      }

      .project-description {
        color: #666;
        font-size: 0.95em;
        line-height: 1.5;
      }

      @media (max-width: 768px) {
        .cv-header h1 {
          font-size: 2em;
        }

        .cv-header .title {
          font-size: 1.2em;
        }

        .cv-header .contact-info {
          gap: 15px;
          font-size: 0.9em;
        }

        .cv-container {
          margin: 20px;
        }

        .cv-header {
          padding: 40px 20px;
        }

        .cv-content {
          padding: 20px;
        }

        .entry {
          padding-left: 15px;
        }

        .projects-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="cv-container">
      <slot />
    </div>
  </body>
</html>
