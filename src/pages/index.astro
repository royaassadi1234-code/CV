---
import Layout from '../layouts/Layout.astro';

const manuscriptImage =
	'https://upload.wikimedia.org/wikipedia/commons/thumb/6/68/Middle_Persian_%28Pahlavi%29_Manuscript_-_Matenadaran_Museum_Yerevan.jpg/2560px-Middle_Persian_%28Pahlavi%29_Manuscript_-_Matenadaran_Museum_Yerevan.jpg';

const expertise = [
	{
		title: 'Avestan and Middle Persian Texts',
		description:
			'Philological work with Zoroastrian textual traditions, historical grammar, and manuscript cultures.'
	},
	{
		title: 'Iranian Religious History',
		description:
			'Research interests across Zoroastrianism, Sasanian cultural history, and the transmission of religious knowledge.'
	},
	{
		title: 'Digital Humanities',
		description:
			'Computational and archival approaches for making ancient Iranian materials easier to study, compare, and preserve.'
	}
];

const highlights = ['Avesta', 'Middle Persian', 'Zoroastrianism', 'Sasanian Empire'];
const homePath = import.meta.env.BASE_URL;
---

<Layout
	title="Roya Assadollahi - Iranian Studies Scholar"
	description="Roya Assadollahi: Iranian Studies, Avesta, Middle Persian, Zoroastrianism, and Digital Humanities"
>
	<style>
		.site-shell {
			min-height: 100vh;
			color: #f7f2e8;
			background:
				linear-gradient(90deg, rgba(24, 21, 18, 0.88), rgba(24, 21, 18, 0.64) 46%, rgba(24, 21, 18, 0.2)),
				linear-gradient(180deg, rgba(24, 21, 18, 0.12), rgba(24, 21, 18, 0.86)),
				var(--manuscript-image) center / cover fixed;
		}

		.topbar {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 24px;
			width: min(1120px, calc(100% - 40px));
			margin: 0 auto;
			padding: 22px 0;
		}

		.brand {
			color: #fffaf0;
			font-family: Georgia, 'Times New Roman', serif;
			font-size: 1rem;
			font-weight: 700;
			letter-spacing: 0.08em;
			text-transform: uppercase;
		}

		.nav {
			display: flex;
			align-items: center;
			gap: 8px;
		}

		.nav a {
			color: rgba(255, 250, 240, 0.84);
			font-size: 0.92rem;
			font-weight: 600;
			text-decoration: none;
			padding: 9px 12px;
			border-radius: 6px;
			transition:
				background 180ms ease,
				color 180ms ease;
		}

		.nav a:hover,
		.nav a:focus-visible {
			color: #fffaf0;
			background: rgba(255, 250, 240, 0.12);
			outline: none;
		}

		.hero {
			display: grid;
			grid-template-columns: minmax(0, 1.08fr) minmax(280px, 0.68fr);
			gap: 48px;
			align-items: end;
			width: min(1120px, calc(100% - 40px));
			min-height: calc(100vh - 96px);
			margin: 0 auto;
			padding: 70px 0 56px;
		}

		.eyebrow {
			color: #d8c393;
			font-size: 0.82rem;
			font-weight: 800;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			margin-bottom: 18px;
		}

		h1 {
			max-width: 820px;
			color: #fffaf0;
			font-family: Georgia, 'Times New Roman', serif;
			font-size: clamp(3rem, 9vw, 6.8rem);
			font-weight: 700;
			line-height: 0.92;
			margin-bottom: 24px;
			text-wrap: balance;
		}

		.lede {
			max-width: 680px;
			color: rgba(255, 250, 240, 0.9);
			font-size: clamp(1.05rem, 2vw, 1.28rem);
			line-height: 1.7;
			margin-bottom: 30px;
		}

		.hero-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 12px;
			margin-bottom: 30px;
		}

		.button {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-height: 44px;
			color: #201b15;
			background: #d8c393;
			border: 1px solid #d8c393;
			border-radius: 6px;
			font-size: 0.95rem;
			font-weight: 800;
			text-decoration: none;
			padding: 0 18px;
		}

		.button.secondary {
			color: #fffaf0;
			background: rgba(255, 250, 240, 0.08);
			border-color: rgba(255, 250, 240, 0.34);
		}

		.tags {
			display: flex;
			flex-wrap: wrap;
			gap: 10px;
			max-width: 650px;
		}

		.tags span {
			color: rgba(255, 250, 240, 0.88);
			background: rgba(255, 250, 240, 0.1);
			border: 1px solid rgba(255, 250, 240, 0.18);
			border-radius: 999px;
			font-size: 0.84rem;
			font-weight: 700;
			padding: 8px 12px;
		}

		.panel {
			background: rgba(255, 250, 240, 0.92);
			color: #241f1a;
			border: 1px solid rgba(255, 250, 240, 0.42);
			border-radius: 8px;
			box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
			padding: 28px;
			backdrop-filter: blur(12px);
		}

		.panel h2 {
			color: #2f281d;
			font-family: Georgia, 'Times New Roman', serif;
			font-size: 1.7rem;
			line-height: 1.15;
			margin-bottom: 16px;
		}

		.credentials {
			display: grid;
			gap: 12px;
			margin: 0 0 24px;
			padding: 0;
			list-style: none;
		}

		.credentials li {
			border-left: 3px solid #a8894a;
			color: #3c342b;
			font-size: 0.95rem;
			line-height: 1.5;
			padding-left: 12px;
		}

		.expertise-list {
			display: grid;
			gap: 16px;
		}

		.expertise-item {
			padding-top: 16px;
			border-top: 1px solid rgba(36, 31, 26, 0.16);
		}

		.expertise-item h3 {
			color: #2f281d;
			font-size: 1rem;
			margin-bottom: 7px;
		}

		.expertise-item p {
			color: #5a5046;
			font-size: 0.93rem;
			line-height: 1.55;
		}

		.image-credit {
			color: rgba(255, 250, 240, 0.68);
			font-size: 0.76rem;
			line-height: 1.5;
			margin-top: 18px;
		}

		.image-credit a {
			color: rgba(255, 250, 240, 0.88);
		}

		@media (max-width: 860px) {
			.site-shell {
				background:
					linear-gradient(180deg, rgba(24, 21, 18, 0.82), rgba(24, 21, 18, 0.64) 52%, rgba(24, 21, 18, 0.9)),
					var(--manuscript-image) center / cover fixed;
			}

			.topbar {
				align-items: flex-start;
				flex-direction: column;
			}

			.nav {
				flex-wrap: wrap;
			}

			.hero {
				grid-template-columns: 1fr;
				gap: 34px;
				padding-top: 42px;
			}
		}

		@media (max-width: 520px) {
			.topbar,
			.hero {
				width: min(100% - 28px, 1120px);
			}

			h1 {
				font-size: clamp(2.6rem, 16vw, 4.4rem);
			}

			.panel {
				padding: 22px;
			}
		}
	</style>

	<main class="site-shell" style={`--manuscript-image: url("${manuscriptImage}")`}>
		<header class="topbar" aria-label="Primary navigation">
			<a class="brand" href={homePath}>Roya Assadollahi</a>
			<nav class="nav">
				<a href="#profile">Profile</a>
				<a href="#expertise">Expertise</a>
				<a href="https://github.com/royaassadi1234-code">GitHub</a>
			</nav>
		</header>

		<section class="hero" id="profile">
			<div class="hero-copy">
				<p class="eyebrow">Iranian Studies | Ancient Iranian Languages</p>
				<h1>Roya Assadollahi</h1>
				<p class="lede">
					Scholar of Iranian Studies with a focus on Avesta, Middle Persian,
					Zoroastrian textual traditions, and digital approaches to ancient
					manuscript cultures.
				</p>
				<div class="hero-actions">
					<a class="button" href="https://github.com/royaassadi1234-code">GitHub Profile</a>
					<a class="button secondary" href="#expertise">Research Focus</a>
				</div>
				<div class="tags" aria-label="Research areas">
					{highlights.map((item) => <span>{item}</span>)}
				</div>
				<p class="image-credit">
					Background:
					<a href="https://commons.wikimedia.org/wiki/File:Middle_Persian_%28Pahlavi%29_Manuscript_-_Matenadaran_Museum_Yerevan.jpg">
						Middle Persian manuscript
					</a>
					by PersianDutchNetwork, CC BY-SA 4.0.
				</p>
			</div>

			<aside class="panel" id="expertise" aria-labelledby="expertise-heading">
				<h2 id="expertise-heading">Academic Profile</h2>
				<ul class="credentials">
					<li>M.A. Iranian Studies</li>
					<li>M.A. Ancient Iranian Languages and Cultures</li>
					<li>B.A. Archeology</li>
				</ul>
				<div class="expertise-list">
					{expertise.map((item) => (
						<section class="expertise-item">
							<h3>{item.title}</h3>
							<p>{item.description}</p>
						</section>
					))}
				</div>
			</aside>
		</section>
	</main>
</Layout>
