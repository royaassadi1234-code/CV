---
import Layout from '../layouts/Layout.astro';

const branches = [
	{
		title: 'Avesta',
		description: 'The sacred texts of Zoroastrianism, composed in Old Avestan and Young Avestan languages. These ancient writings form the spiritual and philosophical foundation of one of the world\'s oldest religions, containing prayers, hymns, and teachings about cosmic order and human morality.'
	},
	{
		title: 'Middle Persian',
		description: 'A historical stage of the Persian language spoken during the Sassanid Empire. Middle Persian literature provides invaluable insights into the administrative, literary, and religious life of the Sasanian period, including translations and commentaries on Avesta.'
	},
	{
		title: 'Zoroastrianism',
		description: 'An ancient Persian religion centered on the worship of Ahura Mazda and the cosmic struggle between good and evil. It profoundly influenced monotheistic religions and shaped Persian culture, philosophy, and ethical systems for millennia.'
	},
	{
		title: 'Digital Humanities',
		description: 'The intersection of digital technology and humanistic inquiry, employing computational methods to analyze, preserve, and interpret cultural and historical texts. It enables new approaches to understanding ancient languages and religious traditions through digital archives and data analysis.'
	},
	{
		title: 'Historical Linguistics',
		description: 'The study of language change and evolution over time, tracing the development of languages through comparative analysis of ancient texts. This discipline reveals connections between ancient Iranian languages and their influence on broader linguistic families.'
	},
	{
		title: 'Sasanian Empire',
		description: 'The last pre-Islamic Persian empire (224-651 CE), representing a pinnacle of Persian civilization. Its sophisticated administrative systems, artistic achievements, and cultural synthesis continue to influence Middle Eastern history and demonstrate the continuity of Persian intellectual traditions.'
	}
];
---

<Layout title="Roya Assadollahi - Iranian Studies Scholar">
	<style>
		.network-container {
			display: flex;
			flex-direction: column;
			align-items: center;
			padding: 60px 40px;
			min-height: 100vh;
			background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
		}

		.network-wrapper {
			position: relative;
			width: 100%;
			max-width: 1200px;
			height: 800px;
			display: flex;
			justify-content: center;
			align-items: center;
		}

		.center-profile {
			position: absolute;
			left: 50%;
			top: 50%;
			transform: translate(-50%, -50%);
			text-align: center;
			z-index: 10;
		}

		.profile-image {
			width: 200px;
			height: 200px;
			border-radius: 50%;
			object-fit: cover;
			border: 5px solid white;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
			margin-bottom: 20px;
		}

		.profile-name {
			color: white;
			font-size: 2em;
			font-weight: 700;
			margin-bottom: 15px;
		}

		.profile-degrees {
			color: rgba(255, 255, 255, 0.95);
			font-size: 0.95em;
			line-height: 1.6;
		}

		.branches-container {
			position: relative;
			width: 100%;
			height: 100%;
		}

		.branch-card {
			position: absolute;
			width: 220px;
			background: white;
			border-radius: 12px;
			padding: 20px;
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
			transition: all 0.3s ease;
			border-left: 5px solid #667eea;
		}

		.branch-card:hover {
			transform: translateY(-8px);
			box-shadow: 0 12px 32px rgba(0, 0, 0, 0.3);
		}

		.branch-card h3 {
			color: #667eea;
			font-size: 1.2em;
			margin-bottom: 12px;
			font-weight: 600;
		}

		.branch-card p {
			color: #333;
			font-size: 0.9em;
			line-height: 1.5;
		}

		/* Card positions in a circular network around center */
		.card-1 { top: 0%; left: 50%; transform: translate(-50%, -50%); }
		.card-2 { top: 16%; right: 5%; transform: translate(0, -50%); }
		.card-3 { top: 50%; right: -5%; transform: translate(0, -50%); }
		.card-4 { bottom: 16%; right: 5%; transform: translate(0, 50%); }
		.card-5 { bottom: 0%; left: 50%; transform: translate(-50%, 50%); }
		.card-6 { bottom: 16%; left: 5%; transform: translate(0, 50%); }
		.card-7 { top: 50%; left: -5%; transform: translate(0, -50%); }
		.card-8 { top: 16%; left: 5%; transform: translate(0, -50%); }

		/* Connection lines */
		.connections-svg {
			position: absolute;
			width: 100%;
			height: 100%;
			top: 0;
			left: 0;
			z-index: 1;
		}

		@media (max-width: 768px) {
			.network-wrapper {
				height: auto;
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 20px;
				padding: 20px;
			}

			.center-profile {
				position: static;
				transform: none;
				grid-column: 1 / -1;
				margin-bottom: 20px;
			}

			.branches-container {
				position: static;
				display: contents;
			}

			.branch-card {
				position: static;
				width: 100%;
			}

			.connections-svg {
				display: none;
			}
		}
	</style>

	<div class="network-container">
		<div class="network-wrapper">
			<svg class="connections-svg" viewBox="0 0 1200 800">
				<!-- Connection lines from center to each card -->
				<line x1="600" y1="400" x2="600" y2="100" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="950" y2="200" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="1050" y2="400" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="950" y2="600" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="600" y2="700" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="250" y2="600" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="150" y2="400" stroke="#fff" stroke-width="2" opacity="0.3"/>
				<line x1="600" y1="400" x2="250" y2="200" stroke="#fff" stroke-width="2" opacity="0.3"/>
			</svg>

			<div class="branches-container">
				{branches.map((branch, index) => (
					<div class={`branch-card card-${index + 1}`}>
						<h3>{branch.title}</h3>
						<p>{branch.description}</p>
					</div>
				))}
			</div>

			<div class="center-profile">
				<img 
					src="https://www.geschkult.fu-berlin.de/e/iranistik/mitarbeiter/ehemalige/Roya-Assadollahi/index.html"
					alt="Roya Assadollahi"
					class="profile-image"
					onerror="this.src='https://via.placeholder.com/200?text=Roya+Assadollahi'"
				/>
				<div class="profile-name">Roya Assadollahi</div>
				<div class="profile-degrees">
					<div>M.A. Iranian Studies</div>
					<div>M.A. Ancient Iranian Languages and Cultures</div>
					<div>B.A. Archeology</div>
				</div>
			</div>
		</div>
	</div>

			</div>
		</div>

		<!-- Languages Section -->
		<div class="cv-section">
			<h2 class="section-title">Languages</h2>
			<div class="skills-list">
				<div class="skill-tag">English (Fluent)</div>
				<div class="skill-tag">Spanish (Intermediate)</div>
			</div>
		</div>
	</div>
</Layout>
