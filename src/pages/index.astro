---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Professional CV">
	<div class="cv-header">
		<h1>Your Name</h1>
		<div class="title">Full Stack Developer</div>
		<div class="contact-info">
			<span>📧 your.email@example.com</span>
			<span>📱 +1 (555) 123-4567</span>
			<span>📍 City, Country</span>
			<span>🔗 github.com/yourprofile</span>
		</div>
	</div>

	<div class="cv-content">
		<!-- About Section -->
		<div class="cv-section">
			<h2 class="section-title">About Me</h2>
			<p class="entry-description">
				I'm a passionate developer with expertise in building modern web applications. With a strong foundation in full-stack development, I create scalable, efficient, and user-friendly solutions. I'm committed to continuous learning and staying updated with the latest technologies.
			</p>
		</div>

		<!-- Experience Section -->
		<div class="cv-section">
			<h2 class="section-title">Professional Experience</h2>
			
			<div class="entry">
				<div class="entry-header">
					<div>
						<div class="entry-title">Senior Developer</div>
						<div class="entry-subtitle">Tech Company Inc.</div>
					</div>
					<div class="entry-date">2022 - Present</div>
				</div>
				<p class="entry-description">
					Led the development of multiple microservices and frontend applications using React and Node.js. Improved application performance by 40% through optimization techniques. Mentored junior developers and conducted code reviews.
				</p>
			</div>

			<div class="entry">
				<div class="entry-header">
					<div>
						<div class="entry-title">Full Stack Developer</div>
						<div class="entry-subtitle">Digital Solutions Ltd.</div>
					</div>
					<div class="entry-date">2020 - 2022</div>
				</div>
				<p class="entry-description">
					Developed and maintained web applications using React, Vue.js, and Node.js. Implemented RESTful APIs and real-time features. Collaborated with UX/UI designers to deliver pixel-perfect implementations.
				</p>
			</div>

			<div class="entry">
				<div class="entry-header">
					<div>
						<div class="entry-title">Junior Developer</div>
						<div class="entry-subtitle">StartUp Ventures</div>
					</div>
					<div class="entry-date">2019 - 2020</div>
				</div>
				<p class="entry-description">
					Developed front-end components using JavaScript and HTML/CSS. Fixed bugs and implemented new features based on user feedback. Participated in agile development cycles.
				</p>
			</div>
		</div>

		<!-- Education Section -->
		<div class="cv-section">
			<h2 class="section-title">Education</h2>
			
			<div class="entry">
				<div class="entry-header">
					<div>
						<div class="entry-title">Bachelor of Science in Computer Science</div>
						<div class="entry-subtitle">University of Technology</div>
					</div>
					<div class="entry-date">2015 - 2019</div>
				</div>
				<p class="entry-description">
					GPA: 3.8/4.0 | Honors: Cum Laude | Relevant Coursework: Data Structures, Algorithms, Web Development, Database Design
				</p>
			</div>

			<div class="entry">
				<div class="entry-header">
					<div>
						<div class="entry-title">Advanced JavaScript and React Certification</div>
						<div class="entry-subtitle">Online Learning Platform</div>
					</div>
					<div class="entry-date">2020</div>
				</div>
			</div>
		</div>

		<!-- Skills Section -->
		<div class="cv-section">
			<h2 class="section-title">Skills</h2>
			<div class="skills-list">
				<div class="skill-tag">JavaScript</div>
				<div class="skill-tag">React</div>
				<div class="skill-tag">Vue.js</div>
				<div class="skill-tag">Node.js</div>
				<div class="skill-tag">Express</div>
				<div class="skill-tag">TypeScript</div>
				<div class="skill-tag">REST APIs</div>
				<div class="skill-tag">GraphQL</div>
				<div class="skill-tag">MongoDB</div>
				<div class="skill-tag">PostgreSQL</div>
				<div class="skill-tag">Docker</div>
				<div class="skill-tag">Git</div>
				<div class="skill-tag">AWS</div>
				<div class="skill-tag">HTML/CSS</div>
				<div class="skill-tag">Agile</div>
			</div>
		</div>

		<!-- Projects Section -->
		<div class="cv-section">
			<h2 class="section-title">Featured Projects</h2>
			<div class="projects-grid">
				<div class="project-card">
					<div class="project-title">E-Commerce Platform</div>
					<p class="project-description">
						Built a full-stack e-commerce platform with React, Node.js, and MongoDB. Implemented payment processing, real-time inventory management, and admin dashboard.
					</p>
				</div>
				<div class="project-card">
					<div class="project-title">Task Management App</div>
					<p class="project-description">
						Developed a collaborative task management application with real-time updates using WebSockets. Features include kanban board, team collaboration, and notifications.
					</p>
				</div>
				<div class="project-card">
					<div class="project-title">Analytics Dashboard</div>
					<p class="project-description">
						Created an interactive analytics dashboard with data visualization libraries. Displays real-time metrics and business intelligence reports.
					</p>
				</div>
			</div>
		</div>

		<!-- Languages Section -->
		<div class="cv-section">
			<h2 class="section-title">Languages</h2>
			<div class="skills-list">
				<div class="skill-tag">English (Fluent)</div>
				<div class="skill-tag">Spanish (Intermediate)</div>
			</div>
		</div>
	</div>
</Layout>
